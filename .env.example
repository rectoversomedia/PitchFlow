# ============================================
# PITCHFLOW ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git!

# ============================================
# SERVER-SIDE KEYS (NEVER prefix with NEXT_PUBLIC_)
# ============================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# NextAuth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=generate-with-openssl-rand-base64-32

# ============================================
# CLIENT-SIDE KEYS (MUST prefix with NEXT_PUBLIC_)
# ============================================

# Supabase Project URL (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google OAuth Client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# ============================================
# AUTH CONFIGURATION
# ============================================

# For development: http://localhost:3000
# For production: https://pitchflow-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================
# For Vercel deployment, add these as Environment Variables
# in the Vercel Dashboard > Settings > Environment Variables
#
# Server-side (Runtime: Server-side only):
# - OPENAI_API_KEY
# - GOOGLE_CLIENT_SECRET
# - AUTH_SECRET
# - NEXTAUTH_URL
#
# Client-side (Runtime: Client-side):
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - NEXT_PUBLIC_GOOGLE_CLIENT_ID
#
# You can also use Vercel Secrets for extra security:
# vercel secrets add pitchflow-openai-api-key "your-key"
