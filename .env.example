# ============================================
# PITCHFLOW ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git!

# ============================================
# SERVER-SIDE KEYS (NEVER prefix with NEXT_PUBLIC_)
# ============================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here

# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# ============================================
# CLIENT-SIDE KEYS (MUST prefix with NEXT_PUBLIC_)
# ============================================

# Supabase Project URL (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google OAuth Client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================
# SENTRY ERROR TRACKING (Optional but recommended)
# ============================================
# Get your DSN from https://sentry.io/settings/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-number

# ============================================
# AUTH CONFIGURATION
# ============================================

# For development: http://localhost:3000
# For production: https://pitchflow.vercel.app (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================
# Optional: Configure Redis URL for distributed rate limiting
# REDIS_URL=redis://localhost:6379

# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================
# For Vercel deployment, add these as Environment Variables
# in the Vercel Dashboard > Settings > Environment Variables
#
# IMPORTANT: Set for ALL environments (Production, Preview, Development)
#
# Server-side (Runtime: Server-side only):
# - OPENAI_API_KEY = sk-proj-...
# - ANTHROPIC_API_KEY = sk-ant-...
# - GOOGLE_CLIENT_SECRET = GOCSPX-...
# - AUTH_SECRET = generate-with-openssl-rand-base64-32
# - AUTH_TRUST_HOST = true
# - SENTRY_DSN = https://...@sentry.io/...
#
# Client-side (Runtime: Client-side):
# - NEXT_PUBLIC_SUPABASE_URL = https://bfzeixmnudtshvscigwm.supabase.co
# - NEXT_PUBLIC_SUPABASE_ANON_KEY = sb_publishable__...
# - NEXT_PUBLIC_GOOGLE_CLIENT_ID = 106581557271-...
